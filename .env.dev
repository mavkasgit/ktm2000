# === KTM-2000 Development Environment ===

# External access
EXTERNAL_PORT=5180
BASE_URL=http://localhost:5180

# Database
POSTGRES_USER=ktm2000_user
POSTGRES_PASSWORD=ktm2000_pass
POSTGRES_DB=ktm2000_dev
POSTGRES_PORT=5202
POSTGRES_DATA_PATH=../data/postgres-dev
POSTGRES_CONTAINER_NAME=ktm2000-postgres

# Internal URLs
DATABASE_URL=postgresql+asyncpg://ktm2000_user:ktm2000_pass@localhost:5202/ktm2000_dev
BACKEND_INTERNAL_URL=http://backend:8000

# Public URLs (derived from BASE_URL)
APP_PUBLIC_URL=${BASE_URL}/api
CORS_ORIGINS=http://localhost:5180

# App settings
SECRET_KEY=ktm2000-dev-secret-change-me
ENV=dev
DEFAULT_TIMEZONE=Europe/Moscow

# Storage
STORAGE_PATH=../storage
UPLOAD_DIR=./data/uploads
BACKUPS_PATH=./data/backups
PRODUCT_PHOTO_DIR=/app/storage/products
IMPORT_STORAGE_DIR=/app/storage/imports
