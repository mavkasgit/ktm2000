# === KTM-2000 Environment Configuration ===
# Copy this file to .env.dev, .env.test, or .env.prod and fill in the values.
# Never commit actual secrets to version control.

# External access
EXTERNAL_PORT=
BASE_URL=

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_DATA_PATH=

# Internal URLs (docker service names — usually don't change)
DATABASE_URL=
BACKEND_INTERNAL_URL=http://backend:8000

# Public URLs (derived from BASE_URL)
APP_PUBLIC_URL=
CORS_ORIGINS=

# App settings
SECRET_KEY=
ENV=
DEFAULT_TIMEZONE=Europe/Moscow

# Storage
STORAGE_PATH=
UPLOAD_DIR=
BACKUPS_PATH=
PRODUCT_PHOTO_DIR=/app/storage/products
IMPORT_STORAGE_DIR=/app/storage/imports
