# === KTM-2000 Test Environment ===

# External access
EXTERNAL_PORT=8100
BASE_URL=http://localhost:8100

# Database
POSTGRES_USER=ktm2000_user
POSTGRES_PASSWORD=ktm2000_pass_test
POSTGRES_DB=ktm2000_test
POSTGRES_PORT=5212
POSTGRES_CONTAINER_NAME=ktm2000-postgres-test
TEST_DATABASE_URL=postgresql+asyncpg://ktm2000_user:ktm2000_pass_test@localhost:5212/ktm2000_test

# Internal URLs (docker service names)
DATABASE_URL=postgresql+asyncpg://ktm2000_user:ktm2000_pass_test@postgres:5432/ktm2000_test
BACKEND_INTERNAL_URL=http://backend:8000

# Public URLs (derived from BASE_URL)
APP_PUBLIC_URL=${BASE_URL}/api
CORS_ORIGINS=http://localhost:8100

# App settings
SECRET_KEY=ktm2000-test-secret-change-me
ENV=test
DEFAULT_TIMEZONE=Europe/Moscow

# Storage
STORAGE_PATH=./storage-test
UPLOAD_DIR=./data/uploads-test
BACKUPS_PATH=./data/backups-test
PRODUCT_PHOTO_DIR=/app/storage/products
IMPORT_STORAGE_DIR=/app/storage/imports
